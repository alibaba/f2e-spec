  "scripts": {
    "build": "rive build",
    "test": "vitest run"
  },
  "dependencies": {
    "postcss": "^8.4.34",
    "postcss-less": "^6.0.0",
    "postcss-scss": "^4.0.9",
    "stylelint-less": "^4.1.0",
    "stylelint-scss": "^7.0.0"
  },
  "peerDependencies": {
    "stylelint": "^17.0.0"
  },
