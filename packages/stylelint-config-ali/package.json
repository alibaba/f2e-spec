  },
  "bugs": {
    "url": "https://github.com/alibaba/f2e-spec/issues"
  },
  "homepage": "https://github.com/alibaba/f2e-spec",
  "author": {
    "name": "Sabo",
    "email": "bowei.jbw@gmail.com"
  },
  "contributors": [
    {
      "name": "Xat_MassacrE",
      "email": "xxat.massacre@gmail.com"
    },
    {
      "name": "Guo Yunhe",
      "email": "i@guoyunhe.me",
      "url": "https://guoyunhe.me/"
    }
  ],
